{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/link-preview.js": {
      "maxDuration": 15
    },
    "api/recipes/import.js": {
      "maxDuration": 20
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
